# Ashbound: Base Survivors — environment variables
# Copy this file to .env.local and fill in the values.

# Network: 84532 = Base Sepolia (testnet), 8453 = Base Mainnet
NEXT_PUBLIC_CHAIN_ID=84532

# AshboundRunBadge contract address — set after deploy.
NEXT_PUBLIC_CONTRACT_ADDRESS=

# AshboundCheckIn contract address — set after deploy.
NEXT_PUBLIC_CHECKIN_ADDRESS=

# WalletConnect Project ID (optional, for the WalletConnect connector).
# Free at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=

# Deploy only — never commit real values.
DEPLOYER_PRIVATE_KEY=

# Basescan API key for contract verification (optional).
BASESCAN_API_KEY=
