# ── ENV-переменные Ashbound: Base Survivors (ТЗ §49) ──
# Скопируй этот файл в .env.local и заполни.

# Сеть: 84532 = Base Sepolia (testnet, MVP), 8453 = Base Mainnet.
NEXT_PUBLIC_CHAIN_ID=84532

# Адрес контракта AshboundRunBadge — заполнить ПОСЛЕ деплоя.
NEXT_PUBLIC_CONTRACT_ADDRESS=

# WalletConnect Project ID (нужен, если добавишь WalletConnect-коннектор).
# Получить бесплатно: https://cloud.walletconnect.com
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=

# ── Только для деплоя контракта (НЕ коммить!) ──
# Приватный ключ кошелька-деплоера.
DEPLOYER_PRIVATE_KEY=

# API-ключ Basescan для верификации контракта (опционально).
BASESCAN_API_KEY=
